-- =============================================================================
-- SISTEMA DE BUSCA DE INIMIGOS
-- =============================================================================
local function obterInimigoValido()
	local meuChar = localPlayer.Character
	if not meuChar or not meuChar:FindFirstChild("HumanoidRootPart") then return nil end
	local meuRoot = meuChar.HumanoidRootPart

	if ALVO_SELECIONADO ~= "Mais Próximo" then
		local pAlvo = Players:FindFirstChild(ALVO_SELECIONADO)
		if pAlvo and pAlvo.Character then
			local char = pAlvo.Character
			local humanoid = char:FindFirstChildOfClass("Humanoid")
			local rootPart = char:FindFirstChild("HumanoidRootPart")
			
			if humanoid and rootPart and humanoid.Health > 0 and not char:FindFirstChildOfClass("ForceField") then
				return char
			end
		end
		return nil 
	end

	local alvoMaisProximo = nil
	local menorDistancia = DISTANCIA_MIRA

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= localPlayer and player.Character then
			local char = player.Character
			local humanoid = char:FindFirstChildOfClass("Humanoid")
			local rootPart = char:FindFirstChild("HumanoidRootPart")

			if humanoid and rootPart and humanoid.Health > 0 and not char:FindFirstChildOfClass("ForceField") then
				local distancia = (meuRoot.Position - rootPart.Position).Magnitude
				if distancia < menorDistancia then
					menorDistancia = distancia
					alvoMaisProximo = char
				end
			end
		end
	end
	return alvoMaisProximo
end

-- =============================================================================
-- LOOP PRINCIPAL (MODO SUBTERRÂNEO)
-- =============================================================================
task.spawn(function()
	local ultimoAtaque = 0

	while true do
		RunService.Heartbeat:Wait()
		
		if AUTOFARM_ATIVO then
			local meuChar = localPlayer.Character
			if meuChar then
				local meuRoot = meuChar:FindFirstChild("HumanoidRootPart")
				local meuHumanoid = meuChar:FindFirstChildOfClass("Humanoid")
				local inimigo = obterInimigoValido()

				if meuRoot and meuHumanoid and inimigo then
					local inimigoRoot = inimigo:FindFirstChild("HumanoidRootPart")
					
					if inimigoRoot then
						-- 1. Anti-Gravidade / Trava de Velocidade
						meuRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)

						-- 2. Teleporte Subterrâneo (Subtrai a profundidade no eixo Y)
						local posicaoDebaixo = inimigoRoot.Position - Vector3.new(0, PROFUNDIDADE_TERRA, 0)
						meuRoot.CFrame = CFrame.new(posicaoDebaixo, inimigoRoot.Position)
						
						-- Câmera acompanha o alvo olhando para cima
						camera.CFrame = CFrame.new(camera.CFrame.Position, inimigoRoot.Position)

						-- 3. Clicker de Ataque / Auto-Equip
						if tick() - ultimoAtaque >= COOLDOWN_ATAQUE then
							ultimoAtaque = tick()

							local ferramenta = localPlayer.Backpack:FindFirstChildOfClass("Tool") or meuChar:FindFirstChildOfClass("Tool")
							if ferramenta and ferramenta.Parent ~= meuChar then
								meuHumanoid:EquipTool(ferramenta)
							end

							VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
							task.wait(0.01)
							VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
						end
					end
				else
					task.wait(0.2)
				end
			end
		end
	end
end)
