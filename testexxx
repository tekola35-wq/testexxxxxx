-- =============================================================================
-- LÓGICA DE SELEÇÃO E ATUALIZAÇÃO DA LISTA DE JOGADORES
-- =============================================================================
local botoesJogadores = {}

local function atualizarListaAlvos()
	for _, obj in ipairs(ScrollingFrame:GetChildren()) do
		if obj:IsA("TextButton") then obj:Destroy() end
	end
	botoesJogadores = {}

	local deuses = {"Mais Próximo"}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer then table.insert(deuses, p.Name) end
	end

	for i, nome in ipairs(deuses) do
		local PlayerBtn = Instance.new("TextButton")
		PlayerBtn.Size = UDim2.new(1, -6, 0, 35)
		PlayerBtn.Font = Enum.Font.Gotham
		PlayerBtn.TextSize = 13
		PlayerBtn.Text = nome
		PlayerBtn.BorderSizePixel = 0
		
		local pCorner = Instance.new("UICorner")
		pCorner.CornerRadius = UDim.new(0, 4)
		pCorner.Parent = PlayerBtn

		if ALVO_SELECIONADO == nome then
			PlayerBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
			PlayerBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
		else
			PlayerBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
			PlayerBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
		end

		PlayerBtn.MouseButton1Click:Connect(function()
			ALVO_SELECIONADO = nome
			atualizarListaAlvos()
		end)

		PlayerBtn.Parent = ScrollingFrame
	end
	
	ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
end

Players.PlayerAdded:Connect(atualizarListaAlvos)
Players.PlayerRemoving:Connect(function(player)
	if ALVO_SELECIONADO == player.Name then
		ALVO_SELECIONADO = "Mais Próximo"
	end
	atualizarListaAlvos()
end)

atualizarListaAlvos()

