local function atualizarLista()
	for _, o in ipairs(ScrollingFrame:GetChildren()) do if o:IsA("TextButton") then o:Destroy() end end
	local lista = {"Mais Próximo"}
	for _, p in ipairs(Players:GetPlayers()) do if p ~= localPlayer then table.insert(lista, p.Name) end end
	
	ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, (#lista * 34))
	
	for _, nome in ipairs(lista) do
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(1, 0, 0, 30)
		b.Text = nome
		b.Font = Enum.Font.Gotham
		b.TextSize = 12
		
		if ALVO_SELECIONADO == nome then
			b.TextColor3 = Color3.fromRGB(255, 255, 255)
			b.BackgroundColor3 = Color3.fromRGB(255, 69, 58)
		else
			b.TextColor3 = Color3.fromRGB(200, 200, 200)
			b.BackgroundColor3 = Color3.fromRGB(58, 58, 60)
		end
		
		b.MouseButton1Click:Connect(function() ALVO_SELECIONADO = nome atualizarLista() end)
		b.Parent = ScrollingFrame
	end
end
Players.PlayerAdded:Connect(atualizarLista) Players.PlayerRemoving:Connect(atualizarLista) atualizarLista()

local function ehAlvoVerdadeiro(player)
	if not player then return false end
	local char = player.Character or workspace:FindFirstChild(player.Name)
	if not char or not char:IsDescendantOf(workspace) then return false end
	local hum = char:FindFirstChildOfClass("Humanoid")
	if not hum or hum.Health <= 0 then return false end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return false end
	return true
end

local function pegarInimigo()
	if ALVO_SELECIONADO ~= "Mais Próximo" then
		local p = Players:FindFirstChild(ALVO_SELECIONADO)
		if p and ehAlvoVerdadeiro(p) then return pegarRoot(p), p.Character end
		return nil, nil
	end
	
	local meuRoot = pegarRoot(localPlayer)
	if not meuRoot then return nil, nil end
	
	local alvo, charAlvo, menorDist = nil, nil, 99999
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer and ehAlvoVerdadeiro(p) then
			local r = pegarRoot(p)
			if r then
				local d = (meuRoot.Position - r.Position).Magnitude
				if d < menorDist then 
					menorDist = d 
					alvo = r 
					charAlvo = p.Character 
				end
			end
		end
	end
	return alvo, charAlvo
end

local ATACANDO = false

-- =============================================================================
-- LOOP DE RENDERIZAÇÃO: EVASÃO DE CONTRATEMPOS E ANTIVID
-- =============================================================================
RunService.Stepped:Connect(function()
	local meuRoot = pegarRoot(localPlayer)
	if not meuRoot then return end
	
	if ANTI_STRIP_STUN then
		quebrarControleFisico()
	end
	
	-- Mecânica de Esquiva Preventiva por Distância Absoluta
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= localPlayer and ehAlvoVerdadeiro(p) then
			local oppRoot = pegarRoot(p)
			if oppRoot then
				local dist = (meuRoot.Position - oppRoot.Position).Magnitude
				if dist < DISTANCIA_ESQUIVA and not ATACANDO and not AUTOFARM_ATIVO then
					meuRoot.CFrame = meuRoot.CFrame * CFrame.new(0, 0, 5)
				end
			end
		end
	end
	
	if meuRoot.Position.Y < LIMITE_VOID or math.abs(meuRoot.Position.X) > 50000 or math.abs(meuRoot.Position.Z) > 50000 then
		meuRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		meuRoot.CFrame = CFrame.new(pegarPosicaoSpawn())
		return
	end
	
	if not AUTOFARM_ATIVO then return end
	
	meuRoot.AssemblyLinearVelocity = Vector3.new(0,0,0)
	
	-- CORREÇÃO PRINCIPAL: Só vai para a altura segura se não estiver ativamente em combate
	local inimigoRoot, inimigoChar = pegarInimigo()
	if not inimigoRoot and not ATACANDO then
		meuRoot.CFrame = CFrame.new(meuRoot.Position.X, ALTURA_SEGURA, meuRoot.Position.Z)
	end
end)

-- Loop de Farm / Ataque Seguro Otimizado
task.spawn(function()
	while true do
		task.wait(0.01)
		if AUTOFARM_ATIVO then
			local meuRoot = pegarRoot(localPlayer)
			local meuChar = localPlayer.Character or workspace:FindFirstChild(localPlayer.Name)
			local inimigoRoot, inimigoChar = pegarInimigo()
			
			if meuRoot and meuChar and inimigoRoot and inimigoChar and ehAlvoVerdadeiro(Players:GetPlayerFromCharacter(inimigoChar)) then
				local hum = meuChar:FindFirstChildOfClass("Humanoid")
				
				-- Verifica e equipa a arma sem spammar chamadas pesadas
				local ferramenta = meuChar:FindFirstChildOfClass("Tool")
				if not ferramenta and localPlayer:FindFirstChild("Backpack") then
					ferramenta = localPlayer.Backpack:FindFirstChildOfClass("Tool")
					if ferramenta and hum then 
						hum:EquipTool(ferramenta) 
					end
				end
				
				ATACANDO = true
				-- Teleporta precisamente atrás do CFrame do alvo
				meuRoot.CFrame = inimigoRoot.CFrame * CFrame.new(0, 0, 2.2)
				workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, inimigoRoot.Position)
				
				-- Executa o clique de ataque
				if ferramenta then
					ferramenta:Activate() -- Método oficial e interno mais estável para ferramentas do Roblox
				end
				VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
				task.wait(0.02)
				VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
				
				ATACANDO = false
			else
				ATACANDO = false
			end
		end
	end
end)
