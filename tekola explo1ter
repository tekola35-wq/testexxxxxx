-- =============================================================================
-- MOTOR DE DEFESA E MOVIMENTAÇÃO
-- =============================================================================
local function pegarRoot(player)
	local char = player.Character or workspace:FindFirstChild(player.Name)
	if char then return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso") end
	return nil
end

local function pegarPosicaoSpawn()
	local spawnLocation = workspace:FindFirstChildOfClass("SpawnLocation")
	if spawnLocation then return spawnLocation.Position + Vector3.new(0, 5, 0) end
	return Vector3.new(0, 20, 0)
end

local function quebrarControleFisico()
	local char = localPlayer.Character or workspace:FindFirstChild(localPlayer.Name)
	if not char then return end
	
	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.PlatformStand = false
		hum.Sit = false
		hum:ChangeState(Enum.HumanoidStateType.GettingUp)
	end

	for _, obj in ipairs(char:GetDescendants()) do
		if obj:IsA("BodyMover") or obj:IsA("LinearVelocity") or obj:IsA("VectorForce") or obj:IsA("AlignPosition") then
			obj:Destroy()
		end
	end
end

AntiVoidBtn.MouseButton1Click:Connect(function()
	if AUTOFARM_ATIVO then
		AUTOFARM_ATIVO = false
		FarmBtn.Text = "AUTOFARM: DESATIVADO"
		aplicarEfeitoBotao(FarmBtn, Color3.fromRGB(58, 58, 60))
	end

	aplicarEfeitoBotao(AntiVoidBtn, Color3.fromRGB(255, 69, 58))
	quebrarControleFisico()
	
	local char = localPlayer.Character or workspace:FindFirstChild(localPlayer.Name)
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum then
			hum:ChangeState(Enum.HumanoidStateType.Dead) 
			char:BreakJoints() 
		end
	end
	
	task.wait(0.2)
	local meuRoot = pegarRoot(localPlayer)
	if meuRoot then
		meuRoot.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
		meuRoot.CFrame = CFrame.new(pegarPosicaoSpawn())
	end

	task.wait(0.5)
	aplicarEfeitoBotao(AntiVoidBtn, Color3.fromRGB(175, 82, 222))
end)

