local function atualizarTransparenciaPersonalizada(estadoInvisivel)
	local char = localPlayer.Character or workspace:FindFirstChild(localPlayer.Name)
	if not char then return end
	local valorTransparencia = estadoInvisivel and 1 or 0
	for _, objeto in ipairs(char:GetDescendants()) do
		if objeto:IsA("BasePart") and objeto.Name ~= "HumanoidRootPart" then
			objeto.Transparency = valorTransparencia
		elseif objeto:IsA("Decal") then
			objeto.Transparency = valorTransparencia
		end
	end
end

